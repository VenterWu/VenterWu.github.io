---
import { siteConfig, withBase } from '../utils/config';

const year = new Date().getFullYear();
---

<footer class="border-t border-line/70 bg-surface/70 text-ink backdrop-blur-sm">
  <div class="site-shell grid gap-6 py-8 text-sm sm:grid-cols-[1fr_auto] sm:items-end">
    <div>
      <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-accent">Archive log / {year}</p>
      <p class="mt-2 max-w-xl text-soft">Built with Astro for fast, durable notes by {siteConfig.author.name}.</p>
    </div>
    <nav class="flex flex-wrap gap-3" aria-label="Footer navigation">
      {
        siteConfig.social.map((item) => (
          <a class="archive-link" href={item.href.startsWith('/') ? withBase(item.href) : item.href}>
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</footer>