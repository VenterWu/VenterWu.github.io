---
import LanguageToggle from './LanguageToggle.astro';
import ThemeToggle from './ThemeToggle.astro';
import { routes, siteConfig, withBase } from '../utils/config';

const currentPath = Astro.url.pathname;
const blogPath = withBase(routes.blog);
---

<header class="sticky top-0 z-40 border-b border-line/60 bg-canvas/90 backdrop-blur-md">
  <div class="site-shell py-3">
    <div class="flex items-center justify-between gap-4">
      <a class="focus-ring group flex items-center gap-3 text-ink no-underline" href={withBase('/')} aria-label={`${siteConfig.title} home`}>
        <span class="flex h-11 w-11 items-center justify-center rounded-md border border-line/70 bg-surface font-mono text-sm font-semibold text-accent transition group-hover:border-accent group-hover:bg-muted/70">VF</span>
        <span class="hidden sm:block">
          <span class="block font-mono text-[0.65rem] font-semibold uppercase tracking-[0.18em] text-accent" data-i18n="archive">Archive</span>
          <span class="block text-sm font-semibold text-ink">{siteConfig.title}</span>
        </span>
      </a>
      <span class="flex items-center gap-2">
        <LanguageToggle />
        <ThemeToggle />
      </span>
    </div>
    <nav class="mt-3 flex gap-2 overflow-x-auto pb-1" aria-label="Primary navigation">
      {
        siteConfig.nav.map((item) => {
          const href = withBase(item.href);
          const isNotesBlogRoute = item.href === routes.notes && currentPath.startsWith(blogPath);
          const isActive = currentPath.startsWith(href) || isNotesBlogRoute;
          return (
            <a
              class={`focus-ring shrink-0 rounded-md border px-3 py-2 font-mono text-xs font-semibold uppercase tracking-[0.14em] no-underline transition ${
                isActive ? 'border-accent bg-muted text-ink' : 'border-line/60 bg-surface/70 text-soft hover:border-accent hover:bg-muted/70 hover:text-ink'
              }`}
              href={href}
              aria-current={isActive ? 'page' : undefined}
            >
              <span data-i18n={item.key}>{item.label}</span>
            </a>
          );
        })
      }
    </nav>
  </div>
</header>