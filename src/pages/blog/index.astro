---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import SearchBox from '../../components/SearchBox.astro';
import { getPublishedBlogPosts } from '../../utils/content';
import { routes } from '../../utils/config';

const posts = await getPublishedBlogPosts();
---

<BaseLayout title="Blog" description="All published posts from Venter Field Notes." canonicalPath={routes.blog}>
  <section class="site-shell py-12">
    <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_20rem]">
      <div>
        <p class="label-code">Archive</p>
        <h1 class="mt-2 text-5xl font-semibold text-ink">Blog</h1>
        <p class="mt-4 max-w-2xl text-soft">Published notes, experiments, and implementation writeups.</p>
      </div>
      <SearchBox />
    </div>
    <div class="mt-8 grid gap-5 md:grid-cols-2">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>