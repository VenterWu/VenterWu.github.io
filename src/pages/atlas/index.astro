---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { routes } from '../../utils/config';
---

<BaseLayout title="Atlas" description="Travel, life photos, and place observations." canonicalPath={routes.atlas}>
  <section class="site-shell py-12">
    <p class="label-code" data-i18n="atlas">Atlas</p>
    <h1 class="mt-2 font-serif text-5xl font-medium text-ink">Atlas</h1>
    <p class="mt-4 max-w-2xl text-soft">A future shelf for travel, life photos, local observations, and short notes about places.</p>

    <div class="mt-8 grid gap-5 md:grid-cols-3">
      <article class="archive-panel aspect-[4/3] p-5">
        <p class="label-code">ATL-001</p>
        <h2 class="mt-3 font-serif text-2xl font-medium text-ink">Travel Notes</h2>
        <p class="mt-3 text-sm leading-6 text-soft">Routes, stations, windows, signs, and the texture of moving through a place.</p>
      </article>
      <article class="archive-panel aspect-[4/3] p-5">
        <p class="label-code">ATL-002</p>
        <h2 class="mt-3 font-serif text-2xl font-medium text-ink">Daily Photographs</h2>
        <p class="mt-3 text-sm leading-6 text-soft">A planned image-first view for ordinary light, rooms, meals, and walks.</p>
      </article>
      <article class="archive-panel aspect-[4/3] p-5">
        <p class="label-code">ATL-003</p>
        <h2 class="mt-3 font-serif text-2xl font-medium text-ink">Place Index</h2>
        <p class="mt-3 text-sm leading-6 text-soft">Locations, dates, and recurring observations grouped without forcing a travel diary shape.</p>
      </article>
    </div>
  </section>
</BaseLayout>