---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { routes } from '../../utils/config';
---

<BaseLayout title="Projects" description="Portfolio shelf for small tools, prototypes, and experiments." canonicalPath={routes.projects}>
  <section class="site-shell py-12">
    <p class="label-code" data-i18n="projects">Projects</p>
    <h1 class="mt-2 font-serif text-5xl font-medium text-ink">Projects</h1>
    <p class="mt-4 max-w-2xl text-soft">A quiet portfolio shelf for software experiments, small tools, and notes on how they were built.</p>

    <div class="mt-8 grid gap-5 md:grid-cols-3">
      <article class="archive-panel p-5">
        <p class="label-code">PRJ-001</p>
        <h2 class="mt-3 font-serif text-2xl font-medium text-ink">Personal Blog Web</h2>
        <p class="mt-3 text-sm leading-6 text-soft">Astro, typed content collections, static search, RSS, sitemap, and GitHub Pages deployment.</p>
      </article>
      <article class="archive-panel p-5">
        <p class="label-code">PRJ-002</p>
        <h2 class="mt-3 font-serif text-2xl font-medium text-ink">Content Tools</h2>
        <p class="mt-3 text-sm leading-6 text-soft">Reserved for future migration scripts, image workflows, and small publishing utilities.</p>
      </article>
      <article class="archive-panel p-5">
        <p class="label-code">PRJ-003</p>
        <h2 class="mt-3 font-serif text-2xl font-medium text-ink">Prototype Shelf</h2>
        <p class="mt-3 text-sm leading-6 text-soft">A placeholder for experiments that are useful enough to document but not yet formal enough for a case study.</p>
      </article>
    </div>
  </section>
</BaseLayout>