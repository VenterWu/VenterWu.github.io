---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import SearchBox from '../components/SearchBox.astro';
import TagList from '../components/TagList.astro';
import { getPublishedBlogPosts, getTagStats } from '../utils/content';
import { routes, siteConfig, withBase } from '../utils/config';

const posts = await getPublishedBlogPosts();
const featuredPost = posts.find((post) => post.data.featured) ?? posts[0];
const latestPosts = posts.slice(0, 3);
const tagStats = getTagStats(posts).slice(0, 8);

const indexLinks = [
  { key: 'notes', label: 'Notes', href: routes.notes, description: 'Recent field notes and build logs.' },
  { key: 'essays', label: 'Essays', href: routes.essays, description: 'Longer reflections and shaped writing.' },
  { key: 'projects', label: 'Projects', href: routes.projects, description: 'Software experiments and small tools.' },
  { key: 'atlas', label: 'Atlas', href: routes.atlas, description: 'Travel, life photos, and place observations.' },
  { key: 'archive', label: 'Archive', href: routes.archive, description: 'A dated shelf of everything published.' },
  { key: 'about', label: 'About', href: routes.page('about'), description: 'Who keeps this archive and why.' },
];

const quoteHistory = [
  { date: '2026.06', text: 'see the world as it is and to love it' },
  { date: '2026.05', text: 'make the useful thing calm enough to keep' },
  { date: '2026.04', text: 'small notes, durable paths' },
];
---

<BaseLayout title="Home" description={siteConfig.description} canonicalPath={routes.home}>
  <section class="site-shell py-12 sm:py-16 lg:py-20">
    <div class="grid gap-8 lg:grid-cols-[13rem_minmax(0,1fr)] lg:items-end">
      <div class="flex items-center gap-4 lg:block">
        <div class="flex h-24 w-24 shrink-0 items-center justify-center rounded-md border border-line/70 bg-surface/80 font-serif text-4xl font-medium text-accent shadow-soft lg:h-32 lg:w-32">
          V
        </div>
        <div class="lg:mt-5">
          <p class="label-code">Field note 0001</p>
          <p class="mt-2 text-sm leading-6 text-soft">Portfolio, notebook, and archive.</p>
        </div>
      </div>

      <div>
        <p class="label-code">Current motto</p>
        <h1 class="mt-4 max-w-4xl font-serif text-5xl font-medium leading-[1.02] text-ink sm:text-6xl lg:text-7xl">
          see the world as it is and to love it
        </h1>
        <details class="archive-panel mt-6 max-w-2xl p-4">
          <summary class="cursor-pointer font-mono text-xs font-semibold uppercase tracking-[0.14em] text-accent transition hover:text-ink">
            Motto history
          </summary>
          <ol class="mt-4 space-y-3">
            {
              quoteHistory.map((quote) => (
                <li class="grid gap-2 border-t border-line/50 pt-3 sm:grid-cols-[5rem_1fr]">
                  <span class="font-mono text-xs uppercase tracking-[0.14em] text-soft">{quote.date}</span>
                  <span class="font-serif text-xl leading-snug text-ink">{quote.text}</span>
                </li>
              ))
            }
          </ol>
        </details>
      </div>
    </div>
  </section>

  <section class="site-shell pb-14">
    <div class="grid gap-8 lg:grid-cols-[18rem_minmax(0,1fr)] lg:items-start">
      <aside class="lg:sticky lg:top-32">
        <div class="archive-panel p-4">
          <div class="flex items-center justify-between gap-3">
            <p class="label-code" data-i18n="index">Index</p>
            <span class="rounded-full bg-highlight/35 px-2 py-1 font-mono text-[0.62rem] uppercase tracking-[0.14em] text-soft">Warm archive</span>
          </div>
          <nav class="mt-4 grid gap-2" aria-label="Home index">
            {
              indexLinks.map((item) => (
                <a class="focus-ring group rounded-md border border-line/60 bg-canvas/45 p-3 no-underline transition hover:-translate-y-0.5 hover:border-accent hover:bg-muted/60" href={withBase(item.href)}>
                  <span class="flex items-center justify-between gap-3">
                    <span class="font-mono text-xs font-semibold uppercase tracking-[0.14em] text-ink" data-i18n={item.key}>{item.label}</span>
                    <span class="text-accent transition group-hover:translate-x-0.5" aria-hidden="true">+</span>
                  </span>
                  <span class="mt-2 block text-sm leading-5 text-soft">{item.description}</span>
                </a>
              ))
            }
            <a class="focus-ring group rounded-md border border-line/60 bg-canvas/45 p-3 no-underline transition hover:-translate-y-0.5 hover:border-accent hover:bg-muted/60" href="#search">
              <span class="flex items-center justify-between gap-3">
                <span class="font-mono text-xs font-semibold uppercase tracking-[0.14em] text-ink" data-i18n="search">Search</span>
                <span class="text-accent transition group-hover:translate-x-0.5" aria-hidden="true">+</span>
              </span>
              <span class="mt-2 block text-sm leading-5 text-soft">Find posts, pages, and older notes.</span>
            </a>
          </nav>
        </div>
      </aside>

      <div class="grid gap-8">
        <section>
          <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <p class="label-code" data-i18n="latest">Latest</p>
              <h2 class="mt-2 font-serif text-4xl font-medium text-ink">Recent notes</h2>
            </div>
            <a class="archive-link" href={withBase(routes.notes)} data-i18n="viewAll">View all</a>
          </div>
          <div class="mt-5 grid gap-4 xl:grid-cols-3">
            {latestPosts.map((post) => <PostCard post={post} compact />)}
          </div>
        </section>

        {featuredPost && (
          <section class="archive-panel grid gap-4 bg-muted/45 p-5 sm:grid-cols-[8rem_1fr]">
            <p class="label-code" data-i18n="featured">Featured</p>
            <div>
              <h2 class="font-serif text-3xl font-medium leading-tight text-ink">
                <a class="text-ink no-underline hover:text-accent" href={withBase(routes.blogPost(featuredPost.slug))}>{featuredPost.data.title}</a>
              </h2>
              <p class="mt-3 max-w-3xl text-soft">{featuredPost.data.description}</p>
            </div>
          </section>
        )}

        <section class="archive-panel p-5">
          <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <p class="label-code" data-i18n="topicMap">Topic Map</p>
              <h2 class="mt-2 font-serif text-3xl font-medium text-ink">Browse by recurring threads</h2>
            </div>
            <a class="archive-link" href={withBase(routes.tags)} data-i18n="topicMap">Topic Map</a>
          </div>
          <div class="mt-4">
            <TagList tags={tagStats.map((tag) => tag.label)} />
          </div>
        </section>

        <section id="search">
          <SearchBox />
        </section>
      </div>
    </div>
  </section>

  <section class="site-shell pb-16">
    <div class="grid gap-5 md:grid-cols-2">
      <div class="archive-panel p-5">
        <p class="label-code" data-i18n="atlas">Atlas</p>
        <h2 class="mt-3 font-serif text-3xl font-medium text-ink">Places, walks, and ordinary light</h2>
        <p class="mt-3 text-sm leading-6 text-soft">A future shelf for travel notes, life photos, and observations of cities, rooms, and weather.</p>
        <a class="archive-link mt-5" href={withBase(routes.atlas)} data-i18n="viewAtlas">Open atlas</a>
      </div>
      <div class="archive-panel p-5">
        <p class="label-code" data-i18n="projects">Projects</p>
        <h2 class="mt-3 font-serif text-3xl font-medium text-ink">Small tools and visible experiments</h2>
        <p class="mt-3 text-sm leading-6 text-soft">A portfolio shelf for shipped utilities, prototypes, and notes about how they were made.</p>
        <a class="archive-link mt-5" href={withBase(routes.projects)} data-i18n="viewProjects">Open projects</a>
      </div>
    </div>
  </section>
</BaseLayout>