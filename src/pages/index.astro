---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import SearchBox from '../components/SearchBox.astro';
import TagList from '../components/TagList.astro';
import { getPublishedBlogPosts, getTagStats } from '../utils/content';
import { routes, siteConfig, withBase } from '../utils/config';

const posts = await getPublishedBlogPosts();
const featuredPost = posts.find((post) => post.data.featured) ?? posts[0];
const latestPosts = posts.slice(0, 4);
const tagStats = getTagStats(posts).slice(0, 8);
---

<BaseLayout title="Home" description={siteConfig.description} canonicalPath={routes.home}>
  <section class="border-b border-line bg-surface/70">
    <div class="site-shell grid gap-8 py-12 lg:grid-cols-[minmax(0,1fr)_24rem] lg:py-16">
      <div class="relative min-h-[25rem] border border-line bg-canvas p-6 shadow-hard sm:p-8">
        <div class="absolute right-0 top-0 h-16 w-28 bg-accent" aria-hidden="true"></div>
        <div class="absolute bottom-0 left-0 h-20 w-20 bg-highlight" aria-hidden="true"></div>
        <p class="label-code relative">Personal notes / static signal</p>
        <h1 class="relative mt-6 max-w-3xl text-5xl font-bold leading-[0.95] text-ink sm:text-6xl lg:text-7xl">
          Minimal notes for sharp software thinking.
        </h1>
        <p class="relative mt-6 max-w-2xl text-lg leading-8 text-soft">
          A compact Astro archive with typed Markdown, static search, and a deliberately industrial visual system built for durable reading.
        </p>
        <div class="relative mt-8 flex flex-wrap gap-3">
          <a class="construct-link bg-ink text-surface dark:bg-highlight dark:text-canvas" href={withBase(routes.blog)}>
            Read the blog
          </a>
          <a class="construct-link" href={withBase(routes.page('about'))}>
            About
          </a>
        </div>
      </div>
      <SearchBox />
    </div>
  </section>

  <section class="site-shell py-12">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="label-code">Latest writing</p>
        <h2 class="mt-2 text-3xl font-semibold text-ink">Recent posts</h2>
      </div>
      <a class="construct-link" href={withBase(routes.blog)}>View all</a>
    </div>
    <div class="mt-6 grid gap-5 md:grid-cols-2">
      {latestPosts.map((post) => <PostCard post={post} />)}
    </div>
  </section>

  {featuredPost && (
    <section class="site-shell pb-12">
      <div class="construct-panel grid gap-4 bg-muted p-6 sm:grid-cols-[8rem_1fr]">
        <p class="label-code">Featured</p>
        <div>
        <h2 class="text-3xl font-semibold leading-tight text-ink">
          <a class="text-ink no-underline hover:text-accent" href={withBase(routes.blogPost(featuredPost.slug))}>{featuredPost.data.title}</a>
        </h2>
        <p class="mt-3 max-w-3xl text-soft">{featuredPost.data.description}</p>
        </div>
      </div>
    </section>
  )}

  <section class="site-shell pb-14">
    <div class="construct-panel p-6">
      <p class="label-code">Index terms</p>
      <h2 class="mt-2 text-3xl font-semibold text-ink">Browse tags</h2>
      <div class="mt-4">
        <TagList tags={tagStats.map((tag) => tag.label)} />
      </div>
    </div>
  </section>
</BaseLayout>