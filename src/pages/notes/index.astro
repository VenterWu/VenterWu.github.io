---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import SearchBox from '../../components/SearchBox.astro';
import { getPublishedBlogPosts } from '../../utils/content';
import { routes } from '../../utils/config';

const posts = await getPublishedBlogPosts();
---

<BaseLayout title="Notes" description="Recent notes and build logs from Venter Field Notes." canonicalPath={routes.notes}>
  <section class="site-shell py-12">
    <div class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_20rem]">
      <div>
        <p class="label-code" data-i18n="notes">Notes</p>
        <h1 class="mt-2 font-serif text-5xl font-medium text-ink">Notes</h1>
        <p class="mt-4 max-w-2xl text-soft">Notebook-style entries, implementation notes, learning logs, and other published fragments.</p>
      </div>
      <SearchBox />
    </div>
    <div class="mt-8 grid gap-5 md:grid-cols-2">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </section>
</BaseLayout>