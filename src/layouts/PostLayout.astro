---
import type { MarkdownHeading } from 'astro';
import type { PublishedBlogPost } from '../utils/content';
import BaseLayout from './BaseLayout.astro';
import TagList from '../components/TagList.astro';
import { routes, withBase } from '../utils/config';
import { formatDate, toIsoDate } from '../utils/date';
import { getReadingTime } from '../utils/readingTime';

interface Props {
  post: PublishedBlogPost;
  headings: MarkdownHeading[];
  previousPost?: PublishedBlogPost;
  nextPost?: PublishedBlogPost;
}

const { post, headings, previousPost, nextPost } = Astro.props;
const tocHeadings = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
const updatedDate = post.data.updatedDate ?? post.data.pubDate;
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  canonicalPath={routes.blogPost(post.slug)}
  image={post.data.heroImage ?? routes.og(post.slug)}
  type="article"
  publishedTime={post.data.pubDate}
  modifiedTime={updatedDate}
  tags={post.data.tags}
>
  <article class="site-shell grid gap-8 py-12 lg:grid-cols-[minmax(0,1fr)_16rem]">
    <div class="min-w-0">
      <header class="border-b border-line pb-8">
        <div class="flex flex-wrap items-center gap-2 font-mono text-xs font-semibold uppercase tracking-[0.16em] text-soft">
          <time datetime={toIsoDate(post.data.pubDate)}>{formatDate(post.data.pubDate)}</time>
          <span class="text-accent" aria-hidden="true">/</span>
          <span>{post.data.author}</span>
          <span class="text-accent" aria-hidden="true">/</span>
          <span>{getReadingTime(post.body)}</span>
        </div>
        <h1 class="mt-4 text-5xl font-semibold leading-tight text-ink sm:text-6xl">{post.data.title}</h1>
        <p class="mt-4 max-w-2xl text-lg leading-8 text-soft">{post.data.description}</p>
        <div class="mt-5">
          <TagList tags={post.data.tags} />
        </div>
      </header>

      <div class="content-prose mt-8">
        <slot />
      </div>

      <nav class="mt-12 grid gap-4 border-t border-line pt-8 sm:grid-cols-2" aria-label="Post navigation">
        {
          previousPost ? (
            <a class="focus-ring construct-panel p-4 no-underline hover:bg-muted" href={withBase(routes.blogPost(previousPost.slug))}>
              <span class="font-mono text-xs uppercase tracking-[0.16em] text-soft">Previous</span>
              <span class="mt-2 block font-semibold text-ink">{previousPost.data.title}</span>
            </a>
          ) : (
            <span></span>
          )
        }
        {
          nextPost && (
            <a class="focus-ring construct-panel p-4 text-right no-underline hover:bg-muted" href={withBase(routes.blogPost(nextPost.slug))}>
              <span class="font-mono text-xs uppercase tracking-[0.16em] text-soft">Next</span>
              <span class="mt-2 block font-semibold text-ink">{nextPost.data.title}</span>
            </a>
          )
        }
      </nav>
    </div>

    <aside class="lg:sticky lg:top-24 lg:self-start">
      <div class="construct-panel p-4">
        <h2 class="label-code">On this page</h2>
        {
          tocHeadings.length > 0 ? (
            <ol class="mt-3 space-y-2 text-sm">
              {tocHeadings.map((heading) => (
                <li class={heading.depth === 3 ? 'pl-4' : ''}>
                  <a class="focus-ring rounded-sm text-soft no-underline hover:text-accent" href={`#${heading.slug}`}>
                    {heading.text}
                  </a>
                </li>
              ))}
            </ol>
          ) : (
            <p class="mt-3 text-sm text-soft">No section headings yet.</p>
          )
        }
      </div>
    </aside>
  </article>
</BaseLayout>